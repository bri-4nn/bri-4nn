        "def evaluate_until_sign_change(func, start, step=0.1, max_iterations=1000):\n",
        "    \"\"\"\n",
        "    Evaluate function until sign changes (useful for finding roots)\n",
        "    \"\"\"\n",
        "    x = start\n",
        "    prev_value = func(x)\n",
        "    iterations = 0\n",
        "\n",
        "    print(f\"x = {x:.4f}, f(x) = {prev_value:.4f}\")\n",
        "\n",
        "    while iterations < max_iterations:\n",
        "        x += step\n",
        "        current_value = func(x)\n",
        "\n",
        "        print(f\"x = {x:.4f}, f(x) = {current_value:.4f}\")\n",
        "\n",
        "        # Check for sign change\n",
        "        if prev_value * current_value < 0:\n",
        "            print(f\"\\n✅ Sign change detected between x = {x-step:.4f} and x = {x:.4f}\")\n",
        "            return x-step, x\n",
        "\n",
        "        prev_value = current_value\n",
        "        iterations += 1\n",
        "\n",
        "    print(\"No sign change detected within range\")\n",
        "    return None\n",
        "\n",
        "# Example\n",
        "f = lambda x: 2*x**3 - 2*x - 5\n",
        "result = evaluate_until_sign_change(f, start=0, step=1.0)\n"
