        "from tabulate import tabulate\n",
        "\n",
        "def create_function():\n",
        "    func_str = input(\"Enter a function of x (e.g., x**3 - 4*x + 1): \")\n",
        "\n",
        "    # Create a lambda function from the string\n",
        "    func = eval(f\"lambda x: {func_str}\")\n",
        "    return func\n",
        "\n",
        "def evaluate_until_sign_change(func, start, step=0.1, max_iterations=1000):\n",
        "    \"\"\"\n",
        "    Find an interval [a, b] where the function changes sign.\n",
        "\n",
        "    Args:\n",
        "        func: The function to evaluate\n",
        "        start: Starting x value\n",
        "        step: Step size for incrementing x\n",
        "        max_iterations: Maximum number of iterations\n",
        "\n",
        "    Returns:\n",
        "        tuple: (a, b) where sign change occurs, or None if no change found\n",
        "    \"\"\"\n",
        "    x = start\n",
        "    prev_value = func(x)\n",
        "\n",
        "    for i in range(max_iterations):\n",
        "        x += step\n",
        "        current_value = func(x)\n",
        "\n",
        "        # Check for sign change\n",
        "        if prev_value * current_value < 0:\n",
        "            a = x - step  # Previous x\n",
        "            b = x         # Current x\n",
        "            print(f\"Sign change detected between x={a:.4f} (f={prev_value:.4f}) \"\n",
        "                  f\"and x={b:.4f} (f={current_value:.4f})\")\n",
        "            return (a, b)\n",
        "\n",
        "        prev_value = current_value\n",
        "\n",
        "    print(f\"No sign change detected in range [{start}, {x}]\")\n",
        "    return None\n",
        "\n",
        "def showTable(a,b):\n",
        "  xi = (a+b)/2\n",
        "\n",
        "  headers = [\"i\", \"a\", \"xi\", \"b\", \"f(a)\", \"f(xi)\", \"f(b)\", \"er\"]\n",
        "  data = [[0, a, xi, b, func(a), func(xi), func(b), \"\"]]\n",
        "\n",
        "  iteration = 0\n",
        "  er = 1\n",
        "\n",
        "  while er >= 0.0001:\n",
        "    xi_1 = xi\n",
        "    if (func(xi) < 0 and func(a) >= 0 or func(xi) >= 0 and func(a) < 0):\n",
        "      b = xi\n",
        "      xi = (a+b)/2\n",
        "      er = ((xi - xi_1) / xi)*(-1)\n",
        "      data.append([iteration+1, round(a,4), round(xi,4), round(b,4), round(func(a),4), round(func(xi),4), round(func(b),4), round(er,4)])\n",
        "    elif (func(xi) < 0 and func(b) >= 0 or func(xi) >= 0 and func(b) < 0):\n",
        "      a = xi\n",
        "      xi = (a+b)/2\n",
        "      er = (xi - xi_1) / xi\n",
        "      data.append([iteration+1, round(a,4), round(xi,4), round(b,4), round(func(a),4), round(func(xi),4), round(func(b),4), round(er,4)])\n",
        "    else:\n",
        "      print(\"f(xi) = 0\")\n",
        "      break\n",
        "\n",
        "    iteration += 1\n",
        "\n",
        "  print(tabulate(data, headers=headers, tablefmt=\"grid\"))\n",
        "\n",
        "# Llamada a funciones\n",
        "func = create_function()\n",
        "result = evaluate_until_sign_change(func, start=0, step=1.0)\n",
        "showTable(result[0], result[1])"
